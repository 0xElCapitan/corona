.claude/.skills-disabled/

# LOA framework (vendored — don't track on GitHub)
.claude/*
!.claude/overrides/
!.claude/settings.json

# Beads operation history (ephemeral; .beads/issues.jsonl is the canonical export)
.beads/.br_history/

# Autonomous-execution audit log (ephemeral)
.run/audit.jsonl

# HITL permission-prompt analytics (operator-specific; ephemeral)
grimoires/loa/analytics/

# Agent decision/trajectory logs (auto-generated; volume + low public value)
grimoires/loa/a2a/trajectory/

# Internal validation reports from /validate (framework-internal)
grimoires/loa/a2a/subagent-reports/

# User-provided context for /plan-and-analyze (local-only; no exceptions per operator)
grimoires/loa/context/

# CORONA backtest harness — local-only ingestor cache (Sprint 3)
scripts/corona-backtest/cache/
